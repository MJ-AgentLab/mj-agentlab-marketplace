{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "mj-agentlab-marketplace",
  "owner": {
    "name": "MJ-AgentLab",
    "url": "https://github.com/MJ-AgentLab"
  },
  "metadata": {
    "description": "MJ System 团队插件市场 — 提供文档、Git、n8n、运维等 Claude Code 插件",
    "version": "2.0.0"
  },
  "plugins": [
    {
      "name": "mj-sys-doc",
      "source": "./plugins/mj-sys-doc",
      "description": "MJ System 文档工作流技能：规划、编写、校验、迁移、同步、审查",
      "version": "3.0.0",
      "author": { "name": "MJ-AgentLab" },
      "category": "productivity",
      "keywords": ["documentation", "markdown", "obsidian", "review", "validation"],
      "license": "MIT"
    },
    {
      "name": "mj-sys-git",
      "source": "./plugins/mj-sys-git",
      "description": "MJ System Git 工作流技能：分支、提交、推送、PR、Review、同步、清理",
      "version": "2.0.0",
      "author": { "name": "MJ-AgentLab" },
      "category": "developer-tools",
      "keywords": ["git", "github", "branch", "commit", "pull-request", "code-review"],
      "license": "MIT"
    },
    {
      "name": "mj-sys-n8n",
      "source": "./plugins/mj-sys-n8n",
      "description": "MJ System n8n 工作流技能：设计、编写、模板、配置、文档、渲染、晋升",
      "version": "2.0.0",
      "author": { "name": "MJ-AgentLab" },
      "category": "automation",
      "keywords": ["n8n", "workflow", "automation", "template", "deployment"],
      "license": "MIT"
    },
    {
      "name": "mj-sys-ops",
      "source": "./plugins/mj-sys-ops",
      "description": "MJ System 运维技能：环境搭建、环境清理、ETL 触发（ODS→DWD, DWD→DWS）",
      "version": "2.0.0",
      "author": { "name": "MJ-AgentLab" },
      "category": "infrastructure",
      "keywords": ["docker", "environment", "etl", "postgresql", "deployment"],
      "license": "MIT"
    }
  ]
}
