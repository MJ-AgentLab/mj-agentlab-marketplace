# MJ-Sys-Ops Infrastructure Secrets — 9 variables (.env → OS env vars)
# Copy to secrets-sys-ops.conf, fill values, run .\scripts\encrypt-sys-ops-secrets.ps1

# §1 SSH Server Passwords
MJ_SYS_SSH_SERVER_RUNNER_PASSWORD=
MJ_SYS_SSH_SERVER_TEST_PASSWORD=
MJ_SYS_SSH_SERVER_PROD_PASSWORD=
MJ_SYS_SSH_SERVER_CLOUD_PASSWORD=

# §2 PostgreSQL Connection URLs
MJ_SYS_POSTGRES_DEV_URL=
MJ_SYS_POSTGRES_TEST_LAN_URL=
MJ_SYS_POSTGRES_TEST_WAN_URL=
MJ_SYS_POSTGRES_PROD_LAN_URL=
MJ_SYS_POSTGRES_PROD_WAN_URL=
