# MJ-Ops Infrastructure Secrets — 9 variables (.env → OS env vars)
# Copy to secrets-ops.conf, fill values, run .\scripts\encrypt-ops-secrets.ps1

# §1 SSH Server Passwords
SSH_SERVER_RUNNER_PASSWORD=
SSH_SERVER_TEST_PASSWORD=
SSH_SERVER_PROD_PASSWORD=
SSH_SERVER_CLOUD_PASSWORD=

# §2 PostgreSQL Connection URLs
MJ_POSTGRES_DEV_URL=
MJ_POSTGRES_TEST_LAN_URL=
MJ_POSTGRES_TEST_WAN_URL=
MJ_POSTGRES_PROD_LAN_URL=
MJ_POSTGRES_PROD_WAN_URL=
