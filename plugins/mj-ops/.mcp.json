      "args": [
        "/c", "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${MJ_POSTGRES_DEV_URL:-postgresql://admin:admin123@localhost:5432/mj_system_db}"
      ],
      "env": {}
    },
    "postgres-test": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c", "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "${MJ_POSTGRES_TEST_URL:-postgresql://admin:admin123@192.168.0.179:5432/mj_system_db}"
      ],
      "env": {}
    },
