      "env": {
        "SSH_SERVER_DEV_HOST": "192.168.0.126",
        "SSH_SERVER_DEV_USER": "mingjian",
        "SSH_SERVER_DEV_PASSWORD": "${SSH_SERVER_DEV_PASSWORD}",
        "SSH_SERVER_DEV_PORT": "22",
        "SSH_SERVER_DEV_DESCRIPTION": "10-Dev-Server",

        "SSH_SERVER_TEST_HOST": "192.168.0.179",
        "SSH_SERVER_TEST_USER": "mingjian02",
        "SSH_SERVER_TEST_PASSWORD": "${SSH_SERVER_TEST_PASSWORD}",
        "SSH_SERVER_TEST_PORT": "22",
        "SSH_SERVER_TEST_DESCRIPTION": "20-Test-Server",

        "SSH_SERVER_PROD_HOST": "192.168.0.106",
        "SSH_SERVER_PROD_USER": "mingjian03",
